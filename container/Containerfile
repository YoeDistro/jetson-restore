# syntax=docker/dockerfile:1
FROM docker.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
# NVIDIA's flash.sh checks $USER == root rather than the actual UID; the
# Ubuntu base image leaves $USER unset, so even though we run as uid 0 the
# check fails with "flash.sh requires root privilege".
ENV USER=root

# Packages that l4t_flash_prerequisites.sh installs, plus tools the
# entrypoint uses. Pinned to the 22.04 archive at image-build time.
RUN apt-get update && apt-get install -y --no-install-recommends \
        sudo \
        qemu-user-static binfmt-support \
        libxml2 libxml2-utils device-tree-compiler \
        python3 python3-yaml \
        abootimg sshpass openssh-client dosfstools binutils cpio rsync zstd lbzip2 \
        nfs-kernel-server \
        uuid-runtime ca-certificates curl iproute2 \
        cpp \
    && rm -rf /var/lib/apt/lists/*

# l4t_initrd_flash.sh writes a transient symlink into /etc/udev/rules.d/
# during the flash. The container has no udevd to consume the rule, but
# the directory must exist for the symlink syscall to succeed.
RUN mkdir -p /etc/udev/rules.d

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /Linux_for_Tegra
ENTRYPOINT ["/entrypoint.sh"]
